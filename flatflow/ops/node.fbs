include "flatflow/ops/operator.fbs";

namespace flatflow;

/// `SymInt` records a value within the symbolic shape of an operator.
table SymInt {
  coef0: int;  // constant
  coef1: int;  // linear
}

/// `Size` describes the shape of a tensor. Unlike `torch.Size`, it represents
/// constant shapes as symbolic shapes as well.
table Size {
  values: [SymInt];
}

/// `Node` is a data structure that represents individual operations in the
/// computational graph. Each node contains an opcode identifying operators
/// and the input/output shapes of the operator. Unlike `torch.fx.Node`, it
/// excludes operations that are not ATen operators; i.e., operations that are
/// not the target of `call_function`.
table Node {
  op:     Operator;
  inputs: [Size];
  output: Size;
}
